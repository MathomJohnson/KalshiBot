# Supabase (service role — Railway only, never Vercel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kalshi API (Railway only) — Phase 1 uses demo; see docs/rollout-phases.md
KALSHI_API_KEY_ID=your-key-id
KALSHI_PRIVATE_KEY=your-private-key-pem-or-path
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
# Phase 2: https://api.elections.kalshi.com/trade-api/v2

# The Odds API (Railway only)
ODDS_API_KEY=your-odds-api-key
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# Kalshi discovery filters (optional — comma-separated)
# KALSHI_SERIES_TICKERS=KXSOCCER,KXWORLDCUP
# KALSHI_EVENT_TICKERS=KXWORLDCUP-25-ENG

BOT_ENV=paper
WORKER_ID=bot-1
DEPLOYED_VERSION=local